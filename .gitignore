# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the committed production template (no real secrets) is the exception
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# LTAC survey responses (local store)
.data/

# Local git credential (token) — never commit
.env.git

# SSH keys / credentials at the repo root — never commit (E06: secrets live in env only).
# OpenSSH private keys carry no extension, so *.pem above does not catch them.
# Root-anchored (leading /) so nothing under public/ or app/ is caught by accident.
/MaluDB
/MaluDB.pub
/id_ed25519*
/id_rsa*
/id_ecdsa*
/*.key
/*.ppk
/*.ovpn
