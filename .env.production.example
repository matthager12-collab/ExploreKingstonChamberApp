# Production environment template for "Explore Kingston" — DOCUMENTATION ONLY.
#
# This file is COMMITTED and must contain NO real secrets. It records which env
# vars the production deployment needs. Set the real values in your host's
# secret store (Render dashboard env vars, or `fly secrets set ...`) — never in
# git. See render.yaml / fly.toml and docs/OPERATIONS.md.

# Signs and verifies session cookies (src/lib/auth.ts). Use a long random value,
# e.g. `openssl rand -hex 32`. On Render, generateValue:true fills this in.
AUTH_SECRET=

# Free WSDOT access code for live Edmonds–Kingston ferry times (src/lib/wsf.ts).
# Leave unset to serve the bundled fallback schedule instead.
WSDOT_API_KEY=

# Google Maps Embed API key (src/components/town-map.tsx). This is a NEXT_PUBLIC_
# var: it is inlined into the client bundle at BUILD time, so it must be present
# during `npm run build`, not just at runtime.
NEXT_PUBLIC_GMAPS_EMBED_KEY=

# Absolute path to the persistent volume where all mutable state is written
# (accounts, portal overlays, hunts + photos, analytics, survey, maps). Must
# point at the mounted disk on the host. /data matches render.yaml and fly.toml.
DATA_DIR=/data
