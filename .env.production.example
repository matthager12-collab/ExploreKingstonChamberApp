# Production environment template for "Explore Kingston" — DOCUMENTATION ONLY.
#
# This file is COMMITTED and must contain NO real secrets. It records which env
# vars the production deployment needs. Set the real values in your host's
# secret store (Render/Fly for Phase 1; Vercel project Settings -> Environment
# Variables for Phase 2) — never in git. See render.yaml / fly.toml,
# docs/DEPLOY.md and docs/OPERATIONS.md.
#
# Two deploy shapes share this file:
#   Phase 1 (persistent-disk host): AUTH_SECRET + WSDOT_API_KEY +
#     NEXT_PUBLIC_SITE_URL + SETUP_TOKEN + DATA_DIR (state on a mounted volume).
#   Phase 2 (Vercel, serverless): the same app keys, but state moves to
#     the cloud stores below — DATABASE_URL + BLOB_READ_WRITE_TOKEN + the two
#     UPSTASH_* vars — and DATA_DIR is NOT set. Each store auto-detects which
#     backend to use from whether its var is present (hasDb() / hasBlob()).

# Signs and verifies session cookies (src/lib/auth.ts). Use a long random value,
# e.g. `openssl rand -hex 32`. On Render, generateValue:true fills this in.
AUTH_SECRET=

# Free WSDOT access code for live Edmonds–Kingston ferry times (src/lib/wsf.ts).
# Leave unset to serve the bundled fallback schedule instead.
WSDOT_API_KEY=

# Gates POST /api/auth/setup (first-run admin bootstrap) fail-closed — unset
# or wrong token, the endpoint 403s. Only consulted before the first admin
# exists (hasAnyUsers() is checked first), so already-bootstrapped deploys can
# ignore it. On Render, generateValue:true fills this in automatically.
SETUP_TOKEN=

# Absolute production origin for share-card/canonical URLs
# (src/app/layout.tsx metadataBase — "the app spreads by visitors texting
# links"). This is a NEXT_PUBLIC_ var: it is inlined into the client bundle at
# BUILD time, so it must be present during `npm run build`, not just at
# runtime — a dashboard-only change needs a rebuild to take effect.
# e.g. https://explore-kingston.onrender.com
NEXT_PUBLIC_SITE_URL=

# PHASE 1 ONLY. Absolute path to the persistent volume where all mutable state
# is written (accounts, portal overlays, hunts + photos, analytics, survey,
# maps). Must point at the mounted disk on the host. /data matches render.yaml
# and fly.toml. On Vercel (Phase 2) LEAVE THIS UNSET — there is no persistent
# disk; the cloud stores below take over.
DATA_DIR=/data

# --- Phase 2 (Vercel serverless) cloud stores ------------------------------
# Set these on Vercel instead of DATA_DIR. The Vercel Marketplace integrations
# inject them automatically when you install/create each store (see
# docs/DEPLOY.md "Phase 2"); the placeholders below are only to document shape.

# Neon Postgres POOLED connection string (host contains "-pooler"). Backs the
# overlay table (auth, portal overlays, custom hunts, submissions, map views)
# plus the analytics_event / survey_response append tables. Injected by the
# Vercel Neon integration. When set, hasDb() routes every store to Postgres.
DATABASE_URL=

# --- Uploaded images: Cloudflare R2 (E15) ----------------------------------
# The PRIVATE bucket holding every uploaded image: hunt reference photos, hunt
# player submissions, map-feature images and event attachments. All four must
# be set or hasR2() reads as "not configured" — a half-configured store must
# never silently swallow writes.
#
# The bucket is private and the app PROXIES reads through /api/hunts/photo,
# /api/map/image and /api/events/attachment. Nothing is served from r2.dev, and
# no R2 custom domain is used (that would require moving the DNS zone to
# Cloudflare, which is rejected — Chamber DNS and email live at NameHero).
#
# NOTE the R2_IMAGES_ prefix. The off-site BACKUP job owns a DIFFERENT bucket
# via R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_ENDPOINT / R2_BUCKET as
# GitHub Actions secrets. Distinct names so nobody cross-wires served images
# into the encrypted-backup bucket, or vice versa.
R2_IMAGES_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_IMAGES_BUCKET=explore-kingston-images
R2_IMAGES_ACCESS_KEY_ID=
R2_IMAGES_SECRET_ACCESS_KEY=

# Vercel Blob read/write token. LEGACY: superseded by R2 above, kept working so
# an existing deployment does not break mid-migration. Writers prefer R2 when
# it is configured; nothing new should choose Blob.
BLOB_READ_WRITE_TOKEN=

# Upstash Redis REST endpoint — the shared rate limiter (src/lib/rate-limit.ts)
# for auth login + invite redemption. Required on Vercel because in-memory
# limits don't hold across serverless instances. Injected by the Vercel Upstash
# integration.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token, paired with the URL above. Same integration.
UPSTASH_REDIS_REST_TOKEN=

# --- Ops floor (E03) --------------------------------------------------------

# Sentry DSN for server-side error monitoring (src/instrumentation.ts). Leave
# unset to disable Sentry entirely (no-op — no client-side init, no session
# replay, no traces). Server-only: never prefix with NEXT_PUBLIC_. PII off
# (sendDefaultPii: false, tracesSampleRate: 0) — no visitor IPs/cookies/bodies
# reach Sentry. Free tier.
SENTRY_DSN=

# Sentry environment tag ("production" / "staging"). Defaults to "production"
# in src/instrumentation.ts if unset.
SENTRY_ENVIRONMENT=

# Read-only, single-purpose bearer token for the scheduled off-site backup
# workflow (.github/workflows/backup-offsite.yml) to call GET
# /api/admin/backup without an admin session. Rotate quarterly (see
# docs/OPERATIONS.md "Secret rotation"). Generate with `openssl rand -hex 32`.
BACKUP_TOKEN=

# Shared secret the ferry-observe/ferry-accuracy GitHub Actions crons send as
# a Bearer token to /api/ferry/observe and /api/ferry/accuracy. Optional —
# those routes are open (throttled) when this is unset. Rotate quarterly.
FERRY_OBSERVE_TOKEN=

# Set to "1" on the staging service only: makes /robots.txt disallow
# everything (src/app/robots.ts) so search engines never index the staging
# copy. Leave unset in production.
NOINDEX=

# --- E10 geo-IP + ops dashboard ---------------------------------------------

# MaxMind GeoLite2 license key for geo-IP in the Visitor Insights dashboard +
# the ops page (src/lib/geoip.ts). Free MaxMind account + license key (see
# docs/runbooks/GEOIP.md). Leave unset to disable geo entirely (no-op —
# analytics geo shows "Unknown", exactly as before). Server-only: never
# NEXT_PUBLIC_. On Render set via the dashboard (sync:false).
MAXMIND_LICENSE_KEY=

# Which GeoLite2 edition to download/serve. Optional — defaults to GeoLite2-City
# (~70 MB) in code. Set GeoLite2-Country (~6 MB) as the lower-memory fallback if
# Render memory alarms fire.
GEOIP_EDITION=

# Optional Sentry read-API credentials for the /admin/ops "Errors" tile (the
# unresolved-issue count for the last 24 h). ALL THREE must be set or the tile
# degrades to a plain Sentry dashboard link. Create a read-scoped token at
# Sentry → Settings → Auth Tokens (project:read, event:read). Server-only.
SENTRY_OPS_API_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
