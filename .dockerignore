# Keep the Docker build context lean and secret-free. Anything matched here is
# NEVER sent to the daemon, so it can't be COPYed into an image layer.

# Dependencies — reinstalled from the lockfile inside the deps stage.
node_modules
.pnp
.pnp.*

# Build output — regenerated by `npm run build` in the build stage.
.next
out
build
*.tsbuildinfo
next-env.d.ts

# Version control.
.git
.gitignore
.gitattributes

# Local runtime data (accounts, portal edits, hunt photos, analytics). This is
# host-persistent-volume state; it must never be baked into the image.
.data

# Secrets / env. Real values live in the host dashboard or `fly secrets`.
.env
.env.*
!.env.production.example

# Docs & readmes — not needed at runtime.
README.md
docs
AGENTS.md
CLAUDE.md

# Editor / OS / tooling cruft.
.vscode
.idea
.DS_Store
*.pem
.claude
.vercel
coverage

# Logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# The image doesn't need these deployment descriptors themselves.
Dockerfile
.dockerignore
render.yaml
fly.toml
